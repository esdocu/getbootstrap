---
/*
 * Muestra una insignia para identificar la primera versión en la que se agregó algo
 */

interface Props {
  version: string
}

const { version } = Astro.props
---

<small
  class="d-inline-flex mb-3 px-2 py-1 fw-semibold text-success-emphasis bg-success-subtle border border-success-subtle rounded-2"
  >Agregado en v{version}</small
>
