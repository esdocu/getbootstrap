---
/*
 * Muestra una insignia para identificar la versión en la que algo quedó obsoleto
 */

interface Props {
  version: string
}

const { version } = Astro.props
---

<small
  class="d-inline-flex mb-3 px-2 py-1 fw-semibold text-warning-emphasis bg-warning-subtle border border-warning-subtle rounded-2"
>
  Obsoleto en v{version}
</small>
