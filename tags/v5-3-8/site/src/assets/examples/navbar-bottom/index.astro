---
import { getVersionedDocsPath } from '@libs/path'

export const title = 'Ejemplo de barra de navegación inferior'
---

<main class="container">
  <div class="bg-body-tertiary p-5 rounded mt-3">
    <h1>Ejemplo de barra de navegación inferior</h1>
    <p class="lead">Este ejemplo es un ejercicio rápido para ilustrar cómo funciona la barra de navegación inferior.</p>
    <a class="btn btn-lg btn-primary" href={getVersionedDocsPath('/components/navbar')} role="button">Ver documentos de la barra de navegación &raquo;</a>
  </div>
</main>
<nav class="navbar fixed-bottom navbar-expand-sm navbar-dark bg-dark">
  <div class="container-fluid">
    <a class="navbar-brand" href="#">Barra de navegación inferior</a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarCollapse" aria-controls="navbarCollapse" aria-expanded="false" aria-label="Alternar navegación">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarCollapse">
      <ul class="navbar-nav">
        <li class="nav-item">
          <a class="nav-link active" aria-current="page" href="#">Inicio</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="#">Enlace</a>
        </li>
        <li class="nav-item">
          <a class="nav-link disabled" aria-disabled="true">Deshabilitado</a>
        </li>
        <li class="nav-item dropup">
          <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown" aria-expanded="false">Menú desplegable superior</a>
          <ul class="dropdown-menu">
            <li><a class="dropdown-item" href="#">Acción</a></li>
            <li><a class="dropdown-item" href="#">Otra acción</a></li>
            <li><a class="dropdown-item" href="#">Algo más aquí</a></li>
          </ul>
        </li>
      </ul>
    </div>
  </div>
</nav>
