---
// Componente de anuncios específico para la portada de esdocu.com
---

<div id="esdocu-promo-banners">
  <!-- Tarjeta: Mejor Hosting -->
  <div class="promo-card hosting-card">
    <div class="card-glow"></div>
    <div class="badge-icon">🌐</div>
    <div class="card-content">
      <h3 class="card-title">¿Sabías qué?</h3>
      <p class="card-text">
        Para aprovechar al máximo todas las características de Bootstrap necesitarás el <a href="https://esdocu.com/mejor-hosting" target="_blank" rel="noopener">mejor hosting</a>.
      </p>
    </div>
  </div>
</div>

<style>
  #esdocu-promo-banners {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    max-width: 860px;
    margin: 4.5rem auto 1.5rem auto;
    text-align: left;
  }

  .promo-card {
    position: relative;
    display: flex;
    flex-direction: column;
    padding: 1.75rem;
    border-radius: 1.25rem;
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    overflow: hidden;
    z-index: 1;
  }

  /* Light mode default styles */
  .hosting-card {
    background: rgba(255, 255, 255, 0.55);
    border: 1px solid rgba(13, 110, 253, 0.18);
    box-shadow:
      0 4px 6px -1px rgba(13, 110, 253, 0.05),
      0 10px 30px -10px rgba(13, 110, 253, 0.1);
  }

  /* Glow element inside the card */
  .card-glow {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border-radius: 1.25rem;
    opacity: 0;
    transition: opacity 0.4s ease;
    z-index: -1;
    pointer-events: none;
  }

  .hosting-card .card-glow {
    background: radial-gradient(circle at 80% 20%, rgba(13, 110, 253, 0.12), transparent 50%);
  }

  /* Hover states */
  .promo-card:hover {
    transform: translateY(-6px);
  }

  .hosting-card:hover {
    border-color: rgba(13, 110, 253, 0.4);
    box-shadow:
      0 12px 24px -10px rgba(13, 110, 253, 0.15),
      0 20px 40px -15px rgba(13, 110, 253, 0.1);
  }

  .promo-card:hover .card-glow {
    opacity: 1;
  }

  /* Dark mode overrides */
  :global([data-bs-theme='dark']) .hosting-card {
    background: rgba(13, 110, 253, 0.05);
    border: 1px solid rgba(13, 110, 253, 0.25);
    box-shadow:
      0 4px 20px rgba(0, 0, 0, 0.15),
      inset 0 1px 1px rgba(255, 255, 255, 0.1);
  }

  :global([data-bs-theme='dark']) .hosting-card:hover {
    background: rgba(13, 110, 253, 0.08);
    border-color: rgba(13, 110, 253, 0.45);
    box-shadow:
      0 12px 30px -5px rgba(13, 110, 253, 0.2),
      0 20px 50px -10px rgba(0, 0, 0, 0.3);
  }

  :global([data-bs-theme='dark']) .hosting-card .card-glow {
    background: radial-gradient(circle at 80% 20%, rgba(13, 110, 253, 0.2), transparent 50%);
  }

  /* Card content details */
  .badge-icon {
    font-size: 2.25rem;
    margin-bottom: 1rem;
    display: inline-block;
    filter: drop-shadow(0 2px 5px rgba(0, 0, 0, 0.08));
    transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .promo-card:hover .badge-icon {
    transform: scale(1.18) rotate(6deg);
  }

  .card-title {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    color: var(--bs-emphasis-color);
    line-height: 1.35;
    letter-spacing: -0.015em;
  }

  .card-text {
    font-size: 0.925rem;
    color: var(--bs-secondary-color);
    line-height: 1.6;
    margin-bottom: 0;
  }

  .card-text a {
    color: var(--bs-link-color);
    text-decoration: underline;
    font-weight: 600;
  }

  .card-text a:hover {
    color: var(--bs-link-hover-color);
  }

  /* Responsive layout for the card on desktop */
  @media (min-width: 768px) {
    .hosting-card {
      flex-direction: row !important;
      align-items: center;
      gap: 2rem;
    }

    .hosting-card .badge-icon {
      margin-bottom: 0;
      font-size: 2.75rem;
      flex-shrink: 0;
    }

    .hosting-card .card-content {
      flex: 1;
    }
  }
</style>
