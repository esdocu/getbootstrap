// ---------------------------------------------------------------------------
// Resolución del versículo solicitado
// ---------------------------------------------------------------------------
const { id } = Astro.props

// Validación de ID duplicado en tiempo de generación (solo en builds de producción)
if (!import.meta.env.DEV) {
  if (usedIds.has(id)) {
    throw new Error(
      `[VeoBibleBanner] El ID "${id}" ya ha sido utilizado en otra página. Cada versículo solo puede aparecer una vez en el sitio.`
    )
  }
  usedIds.add(id)
}

// Validación de que el ID exista en el catálogo
const verse = verses[id]
if (!verse) {
  const validIds = Object.keys(verses).join(', ')
  throw new Error(`[VeoBibleBanner] El ID "${id}" no existe en el catálogo de versículos. IDs válidos: ${validIds}`)
}

// Construir las dos partes del texto de marketing (antes y después del enlace)
const linkPlaceholder = '{link}'
const parts = verse.marketingText.split(linkPlaceholder)
const textBefore = parts[0] ?? ''
const textAfter = parts[1] ?? ''
---

<aside class="veo-bible-banner my-5" aria-label={`Versículo: ${verse.reference}`}>
  <div class="vbb-glow" aria-hidden="true"></div>
  <div class="vbb-ornament" aria-hidden="true">
    <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path
        d="M14 2C14 2 8 6 8 14C8 22 14 26 14 26C14 26 20 22 20 14C20 6 14 2 14 2Z"
        fill="currentColor"
        opacity="0.15"
      >
      </path>
      <path
        d="M14 5C10.5 8 9 11 9 14C9 17 10.5 20 14 23C17.5 20 19 17 19 14C19 11 17.5 8 14 5Z"
        fill="currentColor"
        opacity="0.25"
      >
      </path>
      <circle cx="14" cy="14" r="3" fill="currentColor" opacity="0.6"></circle>
    </svg>
  </div>
  <div class="vbb-content">
    <blockquote class="vbb-quote">
      <p class="vbb-verse-text">{verse.text}</p>
      <cite class="vbb-reference">— {verse.reference}</cite>
    </blockquote>
    <p class="vbb-cta">
      {textBefore}<a href={verse.url} target="_blank" rel="noopener" class="vbb-link">{verse.linkText}</a>{textAfter}
    </p>
  </div>
</aside>

<style>
  /* ── Contenedor principal ── */
  .veo-bible-banner {
    position: relative;
    padding: 1.75rem 1.75rem 1.5rem 2.25rem;
    border-radius: 0.875rem;
    overflow: hidden;
    z-index: 1;
    text-align: left;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);

    /* Borde izquierdo decorativo */
    border-left: 3px solid rgba(139, 92, 246, 0.55);

    /* Light mode */
    background: rgba(248, 246, 255, 0.6);
    border-top: 1px solid rgba(139, 92, 246, 0.08);
    border-right: 1px solid rgba(139, 92, 246, 0.08);
    border-bottom: 1px solid rgba(139, 92, 246, 0.08);
    box-shadow:
      0 2px 8px -2px rgba(139, 92, 246, 0.06),
      0 8px 24px -8px rgba(139, 92, 246, 0.08);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  /* ── Efecto de brillo (hover) ── */
  .vbb-glow {
    position: absolute;
    inset: 0;
    border-radius: 0.875rem;
    background: radial-gradient(ellipse at 10% 50%, rgba(139, 92, 246, 0.07), transparent 65%);
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
    z-index: -1;
  }

  .veo-bible-banner:hover .vbb-glow {
    opacity: 1;
  }

  /* ── Ornamento decorativo ── */
  .vbb-ornament {
    position: absolute;
    top: 1.25rem;
    right: 1.5rem;
    color: #8b5cf6;
    opacity: 0.55;
    transition:
      transform 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275),
      opacity 0.3s ease;
  }

  .veo-bible-banner:hover .vbb-ornament {
    transform: rotate(15deg) scale(1.1);
    opacity: 0.75;
  }

  /* ── Contenido ── */
  .vbb-content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* ── Cita / versículo ── */
  .vbb-quote {
    margin: 0;
    padding: 0;
    border: none;
  }

  .vbb-verse-text {
    font-size: 1.05rem;
    font-weight: 500;
    line-height: 1.7;
    color: var(--bs-emphasis-color);
    letter-spacing: -0.01em;
    font-style: italic;
    margin: 0 0 0.5rem 0;
    opacity: 0.92;
  }

  .vbb-reference {
    display: block;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #8b5cf6;
    font-style: normal;
    opacity: 0.8;
  }

  /* ── CTA / texto de marketing ── */
  .vbb-cta {
    font-size: 0.875rem;
    color: var(--bs-secondary-color);
    line-height: 1.55;
    margin: 0;
    padding-top: 0.75rem;
    border-top: 1px solid rgba(139, 92, 246, 0.1);
  }

  /* ── Enlace inline ── */
  .vbb-link {
    color: #7c3aed;
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-thickness: 1px;
    transition:
      color 0.2s ease,
      text-decoration-color 0.2s ease;
  }

  .vbb-link:hover {
    color: #6d28d9;
    text-decoration-color: currentColor;
  }

  /* ── Dark mode ── */
  :global([data-bs-theme='dark']) .veo-bible-banner {
    background: rgba(139, 92, 246, 0.04);
    border-left-color: rgba(167, 139, 250, 0.5);
    border-top-color: rgba(139, 92, 246, 0.12);
    border-right-color: rgba(139, 92, 246, 0.12);
    border-bottom-color: rgba(139, 92, 246, 0.12);
    box-shadow:
      0 4px 20px rgba(0, 0, 0, 0.2),
      inset 0 1px 1px rgba(255, 255, 255, 0.04);
  }

  :global([data-bs-theme='dark']) .vbb-glow {
    background: radial-gradient(ellipse at 10% 50%, rgba(139, 92, 246, 0.12), transparent 65%);
  }

  :global([data-bs-theme='dark']) .veo-bible-banner:hover {
    background: rgba(139, 92, 246, 0.07);
    border-left-color: rgba(167, 139, 250, 0.7);
  }

  :global([data-bs-theme='dark']) .vbb-reference {
    color: #a78bfa;
  }

  :global([data-bs-theme='dark']) .vbb-cta {
    border-top-color: rgba(139, 92, 246, 0.15);
  }

  :global([data-bs-theme='dark']) .vbb-link {
    color: #a78bfa;
  }

  :global([data-bs-theme='dark']) .vbb-link:hover {
    color: #c4b5fd;
  }

  :global([data-bs-theme='dark']) .vbb-ornament {
    color: #a78bfa;
  }
</style>
