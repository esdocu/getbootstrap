---
/**
 * VeoBibleBanner — Componente de banner con versículos de la Biblia Reina Valera
 *
 * Uso en MDX:
 *   <VeoBibleBanner id="filipenses-4-13" />
 *
 * El parámetro `id` corresponde al identificador único de un versículo dentro del mapa
 * interno `verses`. El componente valida en tiempo de construcción que cada ID se use
 * una sola vez en todo el sitio.
 */

interface Props {
  /** Identificador único del versículo a mostrar. Debe coincidir con una clave del mapa `verses`. */
  id: string
}

interface Verse {
  /** Referencia bíblica legible (e.g. "Filipenses 4:13") */
  reference: string
  /** Texto del versículo en Reina Valera */
  text: string
  /** URL del capítulo en VeoBible (versión rv1909) */
  url: string
  /** Frase de marketing única que invita a leer en VeoBible */
  marketingText: string
  /** Texto del enlace en negrita dentro de la frase de marketing (el anchor text a posicionar) */
  linkText: string
}

// ---------------------------------------------------------------------------
// Registro global para detectar IDs duplicados en el mismo build
// ---------------------------------------------------------------------------
// Este mecanismo solo es útil en SSG (build estático), donde cada página se
// renderiza exactamente una vez. En el servidor de desarrollo (SSR), el mismo
// proceso Node.js atiende múltiples requests y el Set acumularía IDs entre
// refrescos, generando falsos positivos. Por eso solo lo activamos en builds
// de producción mediante import.meta.env.DEV.
const _usedIds = (globalThis as Record<string, unknown>)['__VeoBibleBannerIds__'] as Set<string> | undefined
const usedIds: Set<string> = _usedIds ?? new Set<string>()
;(globalThis as Record<string, unknown>)['__VeoBibleBannerIds__'] = usedIds

