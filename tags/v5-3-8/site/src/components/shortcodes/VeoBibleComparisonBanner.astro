---
/**
 * VeoBibleComparisonBanner — Banner de comparativas de apps y recursos bíblicos
 *
 * Uso en MDX:
 *   <VeoBibleComparisonBanner id="mejor-app-biblia-1" />
 *
 * El parámetro `id` es el identificador único del texto a mostrar.
 * Cada ID puede usarse una sola vez en el sitio (validación en build).
 *
 * Todos los textos mantienen un tono neutro e informativo, propio de una
 * comparativa seria. Ninguno menciona a VeoBible directamente.
 */

interface Props {
  /** Identificador único del texto a mostrar. Debe coincidir con una clave del mapa `entries`. */
  id: string
}

interface Entry {
  /** Texto del banner antes del enlace (puede quedar vacío) */
  before: string
  /** Anchor text del enlace */
  linkText: string
  /** URL de destino */
  url: string
  /** Texto del banner después del enlace */
  after: string
}

// ---------------------------------------------------------------------------
// Registro global para detectar IDs duplicados en el mismo build
// ---------------------------------------------------------------------------
const _usedIds = (globalThis as Record<string, unknown>)['__VeoBibleComparisonBannerIds__'] as Set<string> | undefined
const usedIds: Set<string> = _usedIds ?? new Set<string>()
;(globalThis as Record<string, unknown>)['__VeoBibleComparisonBannerIds__'] = usedIds

// ---------------------------------------------------------------------------
// Catálogo de entradas
// ---------------------------------------------------------------------------
const entries: Record<string, Entry> = {

