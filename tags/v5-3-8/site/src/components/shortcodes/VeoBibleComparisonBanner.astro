// ---------------------------------------------------------------------------
// Resolución de la entrada solicitada
// ---------------------------------------------------------------------------
const { id } = Astro.props

// Validación de ID duplicado en tiempo de generación (solo en builds de producción)
if (!import.meta.env.DEV) {
  if (usedIds.has(id)) {
    throw new Error(
      `[VeoBibleComparisonBanner] El ID "${id}" ya ha sido utilizado en otra página. Cada entrada solo puede aparecer una vez en el sitio.`
    )
  }
  usedIds.add(id)
}

// Validación de que el ID exista en el catálogo
const entry = entries[id]
if (!entry) {
  const validIds = Object.keys(entries).join(', ')
  throw new Error(
    `[VeoBibleComparisonBanner] El ID "${id}" no existe en el catálogo. IDs válidos: ${validIds}`
  )
}
---

<aside class="veo-comparison-banner my-5" aria-label="Recurso relacionado">
  <div class="vcb-glow" aria-hidden="true"></div>
  <div class="vcb-icon" aria-hidden="true">
    <svg width="22" height="22" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect x="3" y="2" width="10" height="13" rx="1.5" fill="currentColor" opacity="0.18"/>
      <rect x="5" y="4" width="10" height="13" rx="1.5" fill="currentColor" opacity="0.28"/>
      <rect x="7" y="6" width="10" height="13" rx="1.5" stroke="currentColor" stroke-width="1.5" fill="none" opacity="0.85"/>
      <line x1="10" y1="10" x2="14" y2="10" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" opacity="0.7"/>
      <line x1="10" y1="13" x2="16" y2="13" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" opacity="0.7"/>
    </svg>
  </div>
  <p class="vcb-text">
    {entry.before}<a href={entry.url} class="vcb-link" target="_blank" rel="noopener follow">{entry.linkText}</a>{entry.after}
  </p>
</aside>

<style>
  /* ── Contenedor principal ── */
  .veo-comparison-banner {
    position: relative;
    display: flex;
    align-items: flex-start;
    gap: 0.85rem;
    padding: 1.1rem 1.4rem 1.1rem 1.25rem;
    border-radius: 0.75rem;
    overflow: hidden;
    z-index: 1;
    transition: transform 0.25s cubic-bezier(0.16, 1, 0.3, 1);

    /* Borde izquierdo */
    border-left: 3px solid rgba(16, 185, 129, 0.5);

    /* Light mode */
    background: rgba(240, 253, 249, 0.65);
    border-top: 1px solid rgba(16, 185, 129, 0.08);
    border-right: 1px solid rgba(16, 185, 129, 0.08);
    border-bottom: 1px solid rgba(16, 185, 129, 0.08);
    box-shadow:
      0 2px 8px -2px rgba(16, 185, 129, 0.06),
      0 6px 20px -6px rgba(16, 185, 129, 0.08);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  /* ── Efecto de brillo (hover) ── */
  .vcb-glow {
    position: absolute;
    inset: 0;
    border-radius: 0.75rem;
    background: radial-gradient(ellipse at 8% 50%, rgba(16, 185, 129, 0.07), transparent 65%);
    opacity: 0;
    transition: opacity 0.35s ease;
    pointer-events: none;
    z-index: -1;
  }

  .veo-comparison-banner:hover .vcb-glow {
    opacity: 1;
  }

  /* ── Icono ── */
  .vcb-icon {
    flex-shrink: 0;
    margin-top: 0.1rem;
    color: #059669;
    opacity: 0.75;
    transition:
      transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275),
      opacity 0.25s ease;
  }

  .veo-comparison-banner:hover .vcb-icon {
    transform: translateY(-1px) scale(1.08);
    opacity: 1;
  }

  /* ── Texto ── */
  .vcb-text {
    font-size: 0.875rem;
    color: var(--bs-secondary-color);
    line-height: 1.6;
    margin: 0;
  }

  /* ── Enlace inline ── */
  .vcb-link {
    color: #047857;
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-thickness: 1px;
    transition:
      color 0.2s ease,
      text-decoration-color 0.2s ease;
  }

  .vcb-link:hover {
    color: #065f46;
    text-decoration-color: currentColor;
  }

  /* ── Dark mode ── */
  :global([data-bs-theme='dark']) .veo-comparison-banner {
    background: rgba(16, 185, 129, 0.04);
    border-left-color: rgba(52, 211, 153, 0.45);
    border-top-color: rgba(16, 185, 129, 0.1);
    border-right-color: rgba(16, 185, 129, 0.1);
    border-bottom-color: rgba(16, 185, 129, 0.1);
    box-shadow:
      0 4px 20px rgba(0, 0, 0, 0.2),
      inset 0 1px 1px rgba(255, 255, 255, 0.03);
  }

  :global([data-bs-theme='dark']) .vcb-glow {
    background: radial-gradient(ellipse at 8% 50%, rgba(16, 185, 129, 0.1), transparent 65%);
  }

  :global([data-bs-theme='dark']) .veo-comparison-banner:hover {
    background: rgba(16, 185, 129, 0.07);
    border-left-color: rgba(52, 211, 153, 0.65);
  }

  :global([data-bs-theme='dark']) .vcb-icon {
    color: #34d399;
  }

  :global([data-bs-theme='dark']) .vcb-link {
    color: #34d399;
  }

  :global([data-bs-theme='dark']) .vcb-link:hover {
    color: #6ee7b7;
  }
</style>
