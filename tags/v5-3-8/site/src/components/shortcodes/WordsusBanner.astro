---
// Componente de banner horizontal de Wordsus para páginas de contenido
---

<div class="wordsus-banner-horizontal my-4">
  <div class="card-glow"></div>
  <div class="banner-body">
    <div class="banner-icon-container">
      <span class="banner-icon">📚</span>
    </div>
    <div class="banner-text-container">
      <h4 class="banner-title" id="sabias-que">¿Sabías qué?</h4>
      <p class="banner-desc">
        Puedes aprender gratis a optimizar tu WordPress leyendo el libro <a href="https://wordsus.com/es/wordpress-sysadmin" target="_blank" rel="noopener" class="banner-inline-link">WordPress a Escala</a>, donde se explora el mundo de la optimización de WordPress a nivel de infraestructura y administración de sistemas.
      </p>
    </div>
  </div>
  <div class="banner-action">
    <a href="https://wordsus.com/es/wordpress-sysadmin" target="_blank" rel="noopener" class="banner-link">
      <span>Leer "WordPress a Escala"</span>
      <svg class="link-arrow" width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path
          d="M1 8H15M15 8L8 1M15 8L8 15"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
    </a>
  </div>
</div>

<style>
  .wordsus-banner-horizontal {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding: 1.5rem;
    border-radius: 1rem;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    overflow: hidden;
    z-index: 1;
    text-align: left;
    
    /* Light mode defaults */
    background: rgba(255, 255, 255, 0.55);
    border: 1px solid rgba(245, 158, 11, 0.15);
    box-shadow:
      0 4px 6px -1px rgba(245, 158, 11, 0.03),
      0 10px 20px -10px rgba(245, 158, 11, 0.05);
  }

  @media (min-width: 768px) {
    .wordsus-banner-horizontal {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      padding: 1.5rem 2rem;
      gap: 2rem;
    }
  }

  .banner-body {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    flex: 1;
  }

  .banner-icon-container {
    font-size: 2.25rem;
    line-height: 1;
    filter: drop-shadow(0 2px 5px rgba(0, 0, 0, 0.05));
    transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 0.15rem;
  }

  .wordsus-banner-horizontal:hover .banner-icon-container {
    transform: scale(1.15) rotate(5deg);
  }

  .banner-text-container {
    flex: 1;
  }

  .banner-title {
    font-size: 1.15rem;
    font-weight: 700;
    margin: 0 0 0.35rem 0;
    color: var(--bs-emphasis-color);
    line-height: 1.3;
    letter-spacing: -0.01em;
  }

  .banner-desc {
    font-size: 0.9rem;
    color: var(--bs-secondary-color);
    line-height: 1.5;
    margin: 0;
  }

  .banner-inline-link {
    color: #e67e22;
    text-decoration: underline;
    font-weight: 600;
  }

  .banner-inline-link:hover {
    color: #d35400;
  }

  .banner-action {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  /* Beautiful modern CTA buttons */
  .banner-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-weight: 600;
    font-size: 0.9rem;
    text-decoration: none !important;
    padding: 0.6rem 1.25rem;
    border-radius: 0.5rem;
    transition: all 0.3s ease;
    width: 100%;
    
    background: #e67e22;
    color: #fff !important;
  }

  @media (min-width: 768px) {
    .banner-link {
      width: fit-content;
    }
  }

  .banner-link:hover {
    background: #d35400;
    box-shadow: 0 4px 12px rgba(230, 126, 34, 0.3);
  }

  /* Glow effect */
  .card-glow {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border-radius: 1rem;
    opacity: 0;
    transition: opacity 0.4s ease;
    z-index: -1;
    pointer-events: none;
    background: radial-gradient(circle at 90% 50%, rgba(245, 158, 11, 0.08), transparent 60%);
  }

  .wordsus-banner-horizontal:hover {
    transform: translateY(-3px);
    border-color: rgba(245, 158, 11, 0.3);
    box-shadow:
      0 10px 20px -8px rgba(245, 158, 11, 0.12),
      0 15px 30px -10px rgba(245, 158, 11, 0.08);
  }

  .wordsus-banner-horizontal:hover .card-glow {
    opacity: 1;
  }

  /* Dark mode overrides */
  :global([data-bs-theme='dark']) .wordsus-banner-horizontal {
    background: rgba(245, 158, 11, 0.04);
    border: 1px solid rgba(245, 158, 11, 0.22);
    box-shadow:
      0 4px 20px rgba(0, 0, 0, 0.15),
      inset 0 1px 1px rgba(255, 255, 255, 0.05);
  }

  :global([data-bs-theme='dark']) .wordsus-banner-horizontal:hover {
    background: rgba(245, 158, 11, 0.07);
    border-color: rgba(245, 158, 11, 0.4);
    box-shadow:
      0 10px 25px -5px rgba(245, 158, 11, 0.15),
      0 15px 35px -10px rgba(0, 0, 0, 0.25);
  }

  :global([data-bs-theme='dark']) .card-glow {
    background: radial-gradient(circle at 90% 50%, rgba(245, 158, 11, 0.15), transparent 60%);
  }

  /* Arrow animation */
  .link-arrow {
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .banner-link:hover .link-arrow {
    transform: translateX(4px);
  }
</style>
